import java.util.Scanner;

/**
 * StudentGradeCalculator
 * -----------------------
 * DecodeLabs | Project 2: Computational Phase
 *
 * Purpose:
 *   Processes a student's marks across multiple subjects and produces
 *   an accurate performance report: total marks, average percentage,
 *   and an assigned letter grade based on that average.
 *
 * Core concepts demonstrated:
 *   - Variables & arrays (storing per-subject data)
 *   - Loops (collecting input, rendering the report)
 *   - Arithmetic operations (totals, averages)
 *   - Conditional branching (grade classification)
 */
public class StudentGradeCalculator {

    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);

        // Ask how many subjects
        System.out.print("Enter number of subjects: ");
        int numSubjects = scanner.nextInt();
        scanner.nextLine(); // consume leftover newline before reading names

        String[] subjectNames = new String[numSubjects];
        double[] marks = new double[numSubjects];
        double totalMarks = 0;

        // Take name + marks for each subject (out of 100)
        for (int i = 0; i < numSubjects; i++) {
            System.out.print("Enter name for subject " + (i + 1) + ": ");
            subjectNames[i] = scanner.nextLine();

            System.out.print("Enter marks for " + subjectNames[i] + " (out of 100): ");
            double subjectMarks = scanner.nextDouble();

            // Basic validation
            while (subjectMarks < 0 || subjectMarks > 100) {
                System.out.print("Invalid marks. Please enter a value between 0 and 100: ");
                subjectMarks = scanner.nextDouble();
            }
            scanner.nextLine(); // consume leftover newline before next name

            marks[i] = subjectMarks;
            totalMarks += subjectMarks;
        }

        // Calculate average percentage
        double averagePercentage = totalMarks / numSubjects;

        // Assign grade based on average percentage
        char grade;
        if (averagePercentage >= 90) {
            grade = 'A';
        } else if (averagePercentage >= 80) {
            grade = 'B';
        } else if (averagePercentage >= 70) {
            grade = 'C';
        } else if (averagePercentage >= 60) {
            grade = 'D';
        } else if (averagePercentage >= 50) {
            grade = 'E';
        } else {
            grade = 'F';
        }

        // Display results clearly
        System.out.println("\n========== STUDENT GRADE REPORT ==========");
        for (int i = 0; i < numSubjects; i++) {
            System.out.printf("%-20s : %.2f / 100%n", subjectNames[i], marks[i]);
        }
        System.out.println("-------------------------------------------");
        System.out.println("Total Marks         : " + totalMarks + " / " + (numSubjects * 100));
        System.out.printf("Average Percentage   : %.2f%%%n", averagePercentage);
        System.out.println("Final Grade          : " + grade);
        System.out.println("===========================================");

        scanner.close();
    }
}
